#!/usr/bin/env node
"use strict";

require("dotenv").config({ path: require("path").join(__dirname, "../.env") });

const http = require("http");
const mongoose = require("mongoose");
const debug = require("debug")("backend:server");

// ─────────────────────────────────────────────────────────────────────────────
// MongoDB connection helper — falls back to in-memory DB in development
// ─────────────────────────────────────────────────────────────────────────────
async function connectMongo() {
  const uri = process.env.MONGODB_URI;

  // 1. Try the configured URI (Atlas / local)
  if (uri && uri !== "mongodb://localhost:27017/ecommerce") {
    try {
      await mongoose.connect(uri, { serverSelectionTimeoutMS: 5000 });
      console.log("✅ MongoDB connected →", uri.replace(/:\/\/.*@/, "://***@"));
      return;
    } catch (e) {
      console.warn("⚠️  Could not connect to configured MongoDB:", e.message);
    }
  } else {
    // Try local MongoDB briefly
    try {
      await mongoose.connect(uri || "mongodb://localhost:27017/ecommerce", {
        serverSelectionTimeoutMS: 3000,
      });
      console.log("✅ MongoDB connected → localhost:27017/ecommerce");
      return;
    } catch {
      // fall through to in-memory
    }
  }

  // 2. Fall back to mongodb-memory-server (dev/demo mode)
  if (process.env.NODE_ENV === "production") {
    console.error("❌ No MongoDB available in production – exiting.");
    process.exit(1);
  }

  console.log("🧪 Starting in-memory MongoDB (demo mode)...");
  try {
    const { MongoMemoryServer } = require("mongodb-memory-server");
    const mongod = await MongoMemoryServer.create();
    const memUri = mongod.getUri();
    process.env.MONGODB_URI = memUri; // expose to seed script if needed

    await mongoose.connect(memUri);
    console.log("✅ In-memory MongoDB started →", memUri);

    // Auto-seed demo data when using in-memory MongoDB
    console.log("🌱 Auto-seeding demo data...");
    try {
      await require("../scripts/seedDemo").run(memUri);
    } catch (seedErr) {
      console.warn("⚠️  Demo seed failed:", seedErr.message);
    }
    return;
  } catch (e) {
    console.error("❌ mongodb-memory-server failed:", e.message);
    console.log("⚠️  Server starting without DB. Install MongoDB or set MONGODB_URI.");
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Boot sequence
// ─────────────────────────────────────────────────────────────────────────────
(async () => {
  await connectMongo();

  // Load app AFTER connection so models are registered against a live connection
  const app = require("../app");

  const port = normalizePort(process.env.PORT || "3000");
  app.set("port", port);

  const server = http.createServer(app);
  server.listen(port);
  server.on("error", onError);
  server.on("listening", () => {
    const addr = server.address();
    const bind = typeof addr === "string" ? "pipe " + addr : "port " + addr.port;
    console.log(`🚀 Server listening on ${bind}  [${process.env.NODE_ENV || "development"}]`);
    console.log(`   Frontend: ${process.env.FRONTEND_URL || "http://localhost:8000"}`);
    debug("Listening on " + bind);
  });
})();

// ─────────────────────────────────────────────────────────────────────────────
function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;
  if (port >= 0) return port;
  return false;
}

function onError(error) {
  if (error.syscall !== "listen") throw error;
  const bind = typeof port === "string" ? "Pipe " + port : "Port " + port;
  switch (error.code) {
    case "EACCES":
      console.error(bind + " requires elevated privileges");
      process.exit(1);
      break;
    case "EADDRINUSE":
      console.error(bind + " is already in use");
      process.exit(1);
      break;
    default:
      throw error;
  }
}
